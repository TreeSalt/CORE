{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "TRADER_OPS Intel Feed Schema",
    "description": "Schema for alternative data feeds providing alpha signals.",
    "type": "object",
    "properties": {
        "feed_id": {
            "type": "string"
        },
        "source": {
            "type": "string"
        },
        "frequency": {
            "type": "string"
        },
        "signal_type": {
            "enum": [
                "SENTIMENT",
                "FLOW",
                "VOLATILITY",
                "MACRO"
            ]
        },
        "data_format": {
            "enum": [
                "JSON",
                "CSV",
                "H5"
            ]
        }
    },
    "required": [
        "feed_id",
        "source",
        "signal_type"
    ]
}