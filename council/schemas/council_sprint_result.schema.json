{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Council Sprint Plan",
    "type": "object",
    "properties": {
        "artifact_name": {
            "type": "string"
        },
        "version": {
            "type": "string"
        },
        "objectives": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "epics": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "tasks": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "description": {
                                    "type": "string"
                                },
                                "definition_of_done": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}